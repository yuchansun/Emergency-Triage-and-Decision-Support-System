# ── 平常開發（預設，與組員相同）────────────────────────────────────────
# npm run dev → http://localhost:5173，API 直連 127.0.0.1
VITE_USE_SAME_ORIGIN=false

VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_LLM_BASE_URL=http://127.0.0.1:8001
VITE_NHICARD_URL=http://127.0.0.1:8002

# ── iPad 區域網路展示 ────────────────────────────────────────────────────
# 方式一：npm run dev:ipad（會自動設 VITE_USE_SAME_ORIGIN=true）
# 方式二：下方改 true 後 npm run dev
# iPad 書籤：https://你的Mac名稱.local:5173
# VITE_USE_SAME_ORIGIN=true
